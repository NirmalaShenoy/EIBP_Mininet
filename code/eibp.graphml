<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <graph edgedefault="undirected">
	  <node id="C1" />
	  <node id="C2" />
    <node id="D1" />
    <node id="D2" />
    <node id="D3" />
    <node id="A1" />
    <node id="A2" />
    <node id="A3" />
    <node id="H1" />
    <node id="H2" />
    <node id="H3" />

    <edge source="A1" target="H1" />
    <edge source="A2" target="H2" />
    <edge source="A3" target="H3" />

    <edge source="C1" target="C2" />
    <edge source="C1" target="D1" />
    <edge source="C1" target="D2" />
    <edge source="C1" target="D3" />
    <edge source="C2" target="D1" />
    <edge source="C2" target="D2" />
    <edge source="C2" target="D3" />
    <edge source="D1" target="A1" />
    <edge source="D1" target="A2" />
    <edge source="D2" target="A1" />
    <edge source="D2" target="A3" />
    <edge source="D3" target="A2" />
    <edge source="D3" target="A3" />
  </graph>
</graphml>
